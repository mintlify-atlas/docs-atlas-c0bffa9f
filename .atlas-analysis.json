  "keyFeatures": [
    "Persistent Telegram sessions per chat with reply context",
    "Scheduled tasks (cron, interval, one-shot) stored as JSON files",
    "File, image, and voice message support with transcription",
    "Extensible skill system via slash commands",
    "Real-time status updates during agent execution",
    "Self-modifiable codebase that agent can edit at runtime"
  ],
  "publicApiSurface": [
    "/setup - Interactive setup wizard",
    "/commands - Register bot commands with Telegram",
    "/restart - Restart the miniclaw service",
    "/diff - Show git diff of repository",
    "/transcribe - Transcribe voice messages",
    "/chatid - Get Telegram chat ID",
    "/cancel - Cancel current request",
    "/compact - Compact conversation context"
  ]
